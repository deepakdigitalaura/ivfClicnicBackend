    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "payload": "payload",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "seed:contact": "node scripts/seed-contact.mjs",
    "seed:globals": "node scripts/seed-globals.mjs",
