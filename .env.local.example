# Copy to .env.local and fill in. .env.local is gitignored.

# Payload CMS — local PostgreSQL (portable instance on port 5433).
# Start the DB with: powershell -NoProfile -File scripts\pg-local.ps1 start
DATABASE_URI=postgresql://postgres:payload_local_pw@127.0.0.1:5433/bfi_payload
# Any long random string. Used to sign Payload auth tokens.
PAYLOAD_SECRET=
# Any long random string. Guards the /preview (Draft Mode) endpoint.
PREVIEW_SECRET=

# Google Places API key (build-time only, never exposed to the browser)
# Needs Places API enabled + billing in Google Cloud.
GOOGLE_PLACES_API_KEY=

# Email notifications — Resend (used by the /inquiry contact form handler)
# Sign up free at resend.com → API Keys → Create API Key
RESEND_API_KEY=
