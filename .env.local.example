# Copy to .env.local and fill in. .env.local is gitignored.

# ── Sanity CMS (replaces Payload) ─────────────────────────────────────────────
# 1. Go to sanity.io → create a new project named "BFI CMS"
# 2. Copy the Project ID from the project dashboard
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Dataset name — "production" is the default
NEXT_PUBLIC_SANITY_DATASET=production
# API token with "Editor" permissions — create at sanity.io → project → API → Tokens
# Required for server-side Sanity reads (used in robots, sitemap, scripts etc.)
SANITY_API_TOKEN=

# ── Resend (contact form email notifications) ──────────────────────────────────
# Sign up free at resend.com → API Keys → Create API Key
RESEND_API_KEY=

# ── Google Places (build-time only) ───────────────────────────────────────────
# Needs Places API enabled + billing in Google Cloud.
GOOGLE_PLACES_API_KEY=

# ── Legacy — no longer needed (Payload removed) ───────────────────────────────
# DATABASE_URI=
# PAYLOAD_SECRET=
# PREVIEW_SECRET=
# BLOB_READ_WRITE_TOKEN=
# MIGRATE_DATABASE_URI=
