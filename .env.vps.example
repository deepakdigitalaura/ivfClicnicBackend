# ============================================================
# VPS Environment Variables — BFI IVF Clinic
# ============================================================
# Copy this to .env on your VPS or pass these as Docker ENV /
# build-args. Values marked [BUILD] must be passed at
# `docker build` time (baked into the JS bundle). All others
# can be injected at `docker run` time.
# ============================================================

# ── Sanity CMS ───────────────────────────────────────────────
# [BUILD] Sanity project ID — find in sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id_here

# [BUILD] Dataset name (default: production)
NEXT_PUBLIC_SANITY_DATASET=production

# [RUNTIME] Sanity API token with write access (Editor role)
# Required for: saving inquiries, admin panel edits
# Generate at: sanity.io/manage → API → Tokens
SANITY_API_TOKEN=your_sanity_write_token_here

# ── Admin Panel ──────────────────────────────────────────────
# [RUNTIME] Login credentials for /admin-panel
ADMIN_EMAIL=admin@ivfclinic.com
ADMIN_PASSWORD=your_strong_password_here

# ── Inquiry Email Notifications ──────────────────────────────
# [RUNTIME] Resend API key — resend.com dashboard
RESEND_API_KEY=re_your_resend_key_here

# ── Optional ─────────────────────────────────────────────────
# [RUNTIME] Preview / draft mode (for Sanity Studio draft previews)
# PREVIEW_SECRET=any_long_random_string
