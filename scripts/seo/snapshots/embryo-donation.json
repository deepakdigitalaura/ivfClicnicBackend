        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It is a treatment where embryos created from donor eggs and donor sperm are transferred into the recipient's uterus."
              },
              "name": "What is embryo donation?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Couples who need both donor eggs and donor sperm, where the woman has a healthy uterus and can carry a pregnancy."
              },
              "name": "Who needs embryo donation?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Egg or sperm donation replaces only one gamete; embryo donation uses donor eggs and donor sperm together."
              },
              "name": "How is it different from egg or sperm donation?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. The baby will not inherit either partner's genes, but the mother carries and delivers the baby herself."
              },
              "name": "Will the baby be genetically related to us?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "They are created from young egg and sperm donors who pass full medical, genetic and psychological screening."
              },
              "name": "How are the donor embryos screened?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Bavishi Fertility Institute's established donor programme means donor embryos are generally available without long waits."
              },
              "name": "Is there a waiting time?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. The uterus is prepared, a donor embryo is transferred, and a pregnancy test follows — much like a frozen embryo transfer."
              },
              "name": "Does the procedure differ from normal IVF?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. It requires informed consent from both partners and follows the ART Act."
              },
              "name": "Is embryo donation legal in India?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Success depends on the recipient's uterine health and age, embryo quality and other factors. Outcomes are individual and cannot be guaranteed."
              },
              "name": "What are the chances of success?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. The entire process is handled with complete confidentiality."
              },
              "name": "Is the treatment confidential?"
            }
          ]
