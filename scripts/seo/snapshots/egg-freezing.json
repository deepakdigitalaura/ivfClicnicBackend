          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Earlier is better — ideally in your late twenties to early thirties — because egg quality and quantity decline with age. Freezing younger eggs gives the best future chance."
              },
              "name": "What is the best age to freeze eggs?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It varies with age, but more eggs improve the odds. After assessing your reserve, your specialist will advise a target number, sometimes over more than one cycle."
              },
              "name": "How many eggs should I freeze?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The injections cause minimal discomfort and egg retrieval is done under sedation, so it is not painful. Mild bloating afterwards settles quickly."
              },
              "name": "Is egg freezing painful?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "They are thawed, fertilised with sperm by ICSI, and the resulting embryos are transferred to the uterus in an IVF cycle."
              },
              "name": "How are frozen eggs used later?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Vitrification gives high egg-survival rates, though not every egg survives or fertilises — which is why the number frozen matters."
              },
              "name": "Do frozen eggs survive well?"
            }
          ]
