        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It is the use of screened donor sperm to achieve pregnancy, either through intrauterine insemination (IUI) or through IVF with ICSI."
              },
              "name": "What is sperm donation?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "For azoospermia where sperm cannot be retrieved, severe male-factor infertility, a high risk of transmitting a genetic condition, or for single women choosing parenthood."
              },
              "name": "When is donor sperm needed?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Donors undergo medical, genetic and psychological evaluation along with semen analysis and infection screening before their sperm is used."
              },
              "name": "How are sperm donors screened?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "We match on characteristics such as height, build, complexion, eye colour, ethnicity and education wherever possible."
              },
              "name": "How are donors matched to us?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. Bavishi Fertility Institute maintains a large pool of frozen, screened donor sperm ready for use."
              },
              "name": "Is there a waiting time for a donor?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The baby will not inherit the male partner's genes, but the female partner contributes through her eggs and carries the pregnancy herself."
              },
              "name": "Will the baby be genetically related to us?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. It is regulated by the ART (Assisted Reproductive Technology) Act, which protects the rights of everyone involved."
              },
              "name": "Is sperm donation legal in India?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Success varies from case to case and is generally higher for younger women. It depends on the female partner's age and health, egg and embryo quality and the technique used. Outcomes cannot be guaranteed."
              },
              "name": "What are the success rates with donor sperm?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Where the partner's sperm is usable, techniques such as ICSI, IMSI or PICSI, or surgical retrieval (PESA/TESA/TESE), are considered before donor sperm."
              },
              "name": "Can we try with the partner's own sperm first?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Donor-sperm treatment is kept completely confidential."
              },
              "name": "Is the process confidential?"
            }
          ]
        },
