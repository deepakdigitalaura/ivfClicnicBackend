        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes — IMSI is considered safe when performed by experienced specialists, though, as with any procedure, potential risks should be discussed with your doctor."
              },
              "name": "Is IMSI safe?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "IMSI is typically recommended for male-factor infertility, recurrent IVF failures, or previous poor embryo quality, rather than for every couple."
              },
              "name": "Is IMSI suitable for all cases?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. IMSI does not guarantee pregnancy; success depends on the underlying causes of infertility and several individual factors."
              },
              "name": "Does IMSI guarantee success?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "IMSI is a form of ICSI that uses much higher magnification to assess sperm structure in detail before injection, so the embryologist can select the most normal-looking sperm."
              },
              "name": "What is the difference between IMSI and ICSI?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No specific adverse effects have been shown, although sperm being outside the body for longer during selection may, in theory, reduce fertilising capacity. This is minimised by careful lab conditions."
              },
              "name": "Are there any side effects?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The procedure takes a few hours overall, covering sperm selection, egg retrieval and, subsequently, embryo transfer."
              },
              "name": "How long does IMSI take?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Maintain a healthy diet, avoid alcohol and tobacco, manage stress and follow prescribed medications. A short period of abstinence before giving the semen sample may improve morphology."
              },
              "name": "How should I prepare?"
            }
          ]
