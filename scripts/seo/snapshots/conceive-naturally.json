          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Generally one year if the woman is under 35, or six months if she is 35 or older — sooner if there are known issues like irregular cycles or previous surgery."
              },
              "name": "How long should we try naturally before seeing a doctor?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "In the few days leading up to and including ovulation. Tracking cycles, ovulation kits or a scan can help identify this fertile window."
              },
              "name": "When am I most fertile?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Healthy weight, balanced nutrition, not smoking, limiting alcohol and managing stress all support natural conception for both partners."
              },
              "name": "Can lifestyle really improve fertility?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "A simple evaluation is worthwhile to confirm ovulation, healthy tubes and normal sperm, and to catch easily-treated issues early."
              },
              "name": "Do I need tests to conceive naturally?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "We step up gradually — ovulation support, then IUI, then IVF — choosing only what your situation actually needs."
              },
              "name": "What if natural conception doesn't work?"
            }
          ]
