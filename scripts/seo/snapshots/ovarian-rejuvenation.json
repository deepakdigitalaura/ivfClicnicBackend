        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "An emerging therapy, usually ovarian PRP, that aims to reactivate dormant follicles in women with very low reserve or early menopause, to try to improve hormone levels and egg availability."
              },
              "name": "What is ovarian rejuvenation?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Results are inconsistent and the evidence is still developing. Some women show a response; many do not. We are honest about this before you decide."
              },
              "name": "Does it really work?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "PRP uses your own blood, so there is no rejection risk, and the procedure is minimally invasive with only minor side-effects."
              },
              "name": "Is it safe?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Mainly women with very low reserve, early menopause or repeated poor IVF response who wish to explore own-egg options before donor eggs."
              },
              "name": "Who should consider it?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. It is an adjunct that may be tried first; IVF and donor eggs remain the more reliable routes and are kept openly in the plan."
              },
              "name": "Is it a substitute for IVF or donor eggs?"
            }
          ]
        },
