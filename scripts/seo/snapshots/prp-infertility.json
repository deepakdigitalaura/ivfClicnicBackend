        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It uses platelet-rich plasma from your own blood, rich in growth factors, injected into the ovaries (for low reserve) or uterus (for a thin lining) to try to improve the chance of conception."
              },
              "name": "What is PRP therapy in fertility?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Because PRP is made from your own blood, there is no risk of rejection or allergy. The procedure itself is minimally invasive with only minor, short-lived side-effects."
              },
              "name": "Is PRP safe?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. PRP is an emerging therapy with variable results, offered as an adjunct in selected cases. We explain realistic expectations clearly before proceeding."
              },
              "name": "Does PRP guarantee pregnancy?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It is mainly considered for low ovarian reserve, a thin endometrial lining or repeated implantation failure, after a full assessment."
              },
              "name": "Who is PRP suitable for?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. It is used alongside standard fertility treatment such as IVF, not instead of it."
              },
              "name": "Is PRP a substitute for IVF?"
            }
          ]
        },
