          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. \"Ovum\" is simply another word for egg, so the two terms describe exactly the same process."
              },
              "name": "Are \"ovum donation\" and \"egg donation\" the same?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Anonymous donation, where the donor's identity is not disclosed, and known donation, where a friend or family member donates. Eggs may be fresh or frozen."
              },
              "name": "What types of egg donation are available?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Healthy, married young women under 30 who already have at least one healthy living child and pass full medical, genetic and psychological screening."
              },
              "name": "Who can be an egg donor at Bavishi Fertility Institute?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The baby will not inherit your genes, since the eggs come from a donor, but your partner contributes genetically through his sperm, and you carry and deliver the baby yourself."
              },
              "name": "Will the baby be genetically related to me?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "They are fertilised with your partner's sperm in the laboratory, usually using ICSI, and grown into embryos before transfer."
              },
              "name": "How are the donor eggs fertilised?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It is generally considered safe. As with any medical treatment there are small risks, such as medication reactions or pregnancy-related complications, which our team monitors closely."
              },
              "name": "Is egg donation safe?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Because donor eggs come from young donors, success rates are relatively high, but they still depend on factors such as your age, uterine health, sperm quality and embryo quality. No clinic can guarantee pregnancy."
              },
              "name": "What are the success rates with donor eggs?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. It is regulated under the ART Act. Recipients arrange insurance for the donor and sign the required consent covering the donor's medical care."
              },
              "name": "Is egg donation legal in India?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Good-quality embryos that are not transferred can be vitrified (frozen) for future attempts."
              },
              "name": "Can surplus embryos be frozen?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. The entire process — including donor matching — is handled with complete confidentiality."
              },
              "name": "Will my treatment be kept confidential?"
            }
          ]
