          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "IVF mixes sperm and eggs together in a dish to let fertilisation happen naturally. ICSI is a more specialised technique where a single sperm is injected directly into each egg — preferred for male-factor infertility or previous fertilisation failure."
              },
              "name": "What is the difference between IVF and ICSI?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, especially where male-factor issues are involved. ICSI provides a more targeted approach to fertilisation."
              },
              "name": "Is ICSI suitable after a previous IVF failure?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "ICSI overcomes specific obstacles to fertilisation, and is particularly helpful for low count, poor motility or abnormal morphology."
              },
              "name": "How does ICSI help with infertility?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. The frozen specimens are thawed before proceeding with the injection."
              },
              "name": "Can ICSI be done with frozen eggs or sperm?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "From ovarian stimulation to embryo transfer, the process typically takes about 4 to 6 weeks."
              },
              "name": "How long does the ICSI process take?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "ICSI can be used alongside Preimplantation Genetic Testing (PGT) to screen embryos for genetic disorders."
              },
              "name": "Can ICSI screen for genetic disorders?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Cost varies with the clinic, location and your specific needs. Bavishi Fertility Institute offers transparent pricing, interest-free EMI and the Suraksha Kavach package — book a consultation for a personalised estimate."
              },
              "name": "How much does ICSI cost?"
            }
