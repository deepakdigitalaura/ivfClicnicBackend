        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "No. Many fibroids cause no fertility problems. It mainly depends on their position — those bulging into the uterine cavity are the most likely to affect conception."
              },
              "name": "Do fibroids always cause infertility?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Chiefly submucosal fibroids that distort the cavity, and sometimes large intramural fibroids, especially with infertility or recurrent miscarriage."
              },
              "name": "Which fibroids need removal before pregnancy?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. Myomectomy removes the fibroids while preserving the uterus, using minimally-invasive hysteroscopic or laparoscopic techniques where possible."
              },
              "name": "Is fibroid surgery fertility-preserving?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "It depends on the fibroid and the repair, but the uterus is usually given a few months to heal. Your surgeon will advise a safe window."
              },
              "name": "How long after surgery can I try to conceive?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Often yes, but cavity-distorting fibroids are usually treated first to give the embryo the best chance of implanting."
              },
              "name": "Can I do IVF with fibroids?"
            }
          ]
