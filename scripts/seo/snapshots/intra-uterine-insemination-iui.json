          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "The IUI visit typically takes about 1 to 2 hours from start to finish; the insemination itself takes only a few minutes."
              },
              "name": "How long does the IUI process take?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "In IUI, prepared sperm is placed into the uterus near the time of ovulation — suitable for mild male-factor or cervical issues. In IVF, eggs are retrieved and fertilised in the laboratory and the embryo is transferred — used for more complex cases such as blocked tubes or severe male infertility."
              },
              "name": "What is the difference between IUI and IVF?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "IUI is usually not painful. Most women experience only mild discomfort, often described as similar to a Pap smear."
              },
              "name": "Is IUI painful?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Typically 3 to 6 cycles of IUI are suggested, but your doctor will tailor the advice based on your specific situation."
              },
              "name": "How many IUI cycles should I try before IVF?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes. There are generally no specific restrictions against sexual activity following the procedure."
              },
              "name": "Can I have sex after an IUI procedure?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Yes, you can travel after IUI, as the procedure does not require prolonged rest."
              },
              "name": "Can I travel after IUI?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Stress can affect fertility by influencing hormone levels. Relaxation techniques, yoga, meditation and counselling can help."
              },
              "name": "Can stress affect IUI success?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Your doctor may recommend repeating the procedure, adjusting medication, or moving to IVF, based on your medical history."
              },
              "name": "What happens if IUI fails?"
            }
          ]
