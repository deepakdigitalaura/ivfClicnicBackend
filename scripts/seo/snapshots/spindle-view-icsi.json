        {
          "@type": "FAQPage",
          "mainEntity": [
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Conventional ICSI relies on the polar body as a marker for the spindle's location, whereas Spindle View ICSI uses a Polscope to visualise the actual meiotic spindle, reducing the risk of damage."
              },
              "name": "What is the difference between conventional ICSI and Spindle View ICSI?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "A specialised polarised microscope visualises the meiotic spindle in the egg, and the embryologist aligns the spindle to avoid damaging it during sperm injection."
              },
              "name": "How is Spindle View ICSI performed?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Ideal candidates include patients with poor fertilisation in previous IVF cycles, poor-quality embryos, or a low ovarian reserve."
              },
              "name": "Who is an ideal candidate?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "By helping keep the meiotic spindle intact during ICSI, the technique can support better-quality embryos in suitable cases."
              },
              "name": "Can Spindle View ICSI improve embryo quality?"
            },
            {
              "@type": "Question",
              "acceptedAnswer": {
                "@type": "Answer",
                "text": "Success rates vary with individual factors, but studies show patients undergoing spindle-aligned injection can experience better fertilisation rates."
              },
              "name": "What are the success rates?"
            }
          ]
