          "children": [{"mode": "normal", "text": "All website content, graphics, and code are protected by copyright and belong exclusively to Bavishi Fertility Institute or licensors. Reproduction, distribution, or public communication of content requires prior written consent. Content cannot be modified, copied, republished, or used for commercial purposes without authorization.", "type": "text", "style": "", "detail": 0, "format": 0, "version": 1}],
