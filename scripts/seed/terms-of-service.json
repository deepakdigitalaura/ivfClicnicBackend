        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [{"mode": "normal", "text": "Users must comply with laws and good faith principles. Activities that are illicit, infringe third-party rights, or damage or overload the website are prohibited. The following activities are specifically prohibited:", "type": "text", "style": "", "detail": 0, "format": 0, "version": 1}],
