        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [{"mode": "normal", "text": "Personal data is collected for managing information requests, suggestions, and service-related communications. Data is retained for legal compliance periods or until deletion is requested. Processing relies on user consent. Data is not transferred to third parties except when necessary for stated purposes or legally required.", "type": "text", "style": "", "detail": 0, "format": 0, "version": 1}],
          "direction": "ltr", "textStyle": "", "textFormat": 0
        },
        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [{"mode": "normal", "text": "Users may access, correct, delete, limit, object to processing of, or request portability of their personal data. The institute implements required technical and organizational safeguards to protect data integrity and confidentiality.", "type": "text", "style": "", "detail": 0, "format": 0, "version": 1}],
          "direction": "ltr", "textStyle": "", "textFormat": 0
        },
        {
