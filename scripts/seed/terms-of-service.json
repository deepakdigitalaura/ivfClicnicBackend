        {
          "type": "paragraph",
          "format": "",
          "indent": 0,
          "version": 1,
          "children": [{"mode": "normal", "text": "The institute makes efforts to ensure safe browsing but accepts no liability for damages from using incompatible browsers or versions.", "type": "text", "style": "", "detail": 0, "format": 0, "version": 1}],
