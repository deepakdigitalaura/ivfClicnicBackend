          "version": 1,
          "children": [{"mode": "normal", "text": "The website https://ivfclinic.com/ is owned by Bavishi Fertility Institute with registered office at Opp. Manjulal Municipal Garden, Next to Adani CNG & Orion Building, Paldi, Ahmedabad. Website access is free except for telecommunications connection costs.", "type": "text", "style": "", "detail": 0, "format": 0, "version": 1}],
